<%- include('../partials/head', { title: '비밀번호 찾기' , basePath: basePath, appUrl: appUrl }) %>
<%- include('../partials/header') %>
<div class="md-auth">
  <div class="md-auth-box">
    <h1>비밀번호 찾기</h1>
    <% if (error) { %><div class="md-alert md-alert-err"><%= error %></div><% } %>
    <% if (done) { %>
      <div class="md-alert">
        <strong><%= username %></strong> 계정의 비밀번호가 <strong>0000</strong>으로 임시 초기화되었습니다.<br>로그인 후 반드시 변경해 주세요.
      </div>
    <% } %>
    <% if (!done) { %>
    <form action="<%= basePath %>/user/find-password" method="POST" class="md-form">
      <label>아이디</label>
      <input type="text" name="username" required>
      <button type="submit" class="md-btn md-btn-b" style="width:100%;">임시 비밀번호 발급</button>
    </form>
    <% } %>
    <p style="text-align:center;margin-top:16px;font-size:12px;"><a href="<%= basePath %>/user/login">로그인</a></p>
  </div>
</div>
<%- include('../partials/footer') %>
