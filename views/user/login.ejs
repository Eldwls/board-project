<%- include('../partials/head', { title: '로그인' , basePath: basePath, appUrl: appUrl }) %>
<%- include('../partials/header') %>
<div class="md-auth">
  <div class="md-auth-box">
    <h1>LOGIN</h1>
    <% if (error) { %><div class="md-alert md-alert-err"><%= error %></div><% } %>
    <form action="<%= basePath %>/user/login" method="POST" class="md-form">
      <input type="hidden" name="redirect" value="<%= redirect %>">
      <label>아이디</label><input type="text" name="username" required minlength="4">
      <label>비밀번호</label><input type="password" name="password" required minlength="4">
      <button type="submit" class="md-btn md-btn-b" style="width:100%;">로그인</button>
    </form>
    <div class="md-auth-links" style="margin-top:20px;">
      <button type="button" class="md-link-btn" onclick="openModal('findIdModal')">아이디 찾기</button>
      <span style="color:#9e9e9e;">|</span>
      <button type="button" class="md-link-btn" onclick="openModal('findPwModal')">비밀번호 찾기</button>
      <span style="color:#9e9e9e;">|</span>
      <a href="<%= basePath %>/user/register">회원가입</a>
    </div>
  </div>
</div>

<!-- 아이디 찾기 모달 -->
<div class="md-modal" id="findIdModal">
  <div class="md-modal-box">
    <button type="button" class="md-modal-close" onclick="closeModal('findIdModal')">&times;</button>
    <h2>아이디 찾기</h2>
    <p class="md-modal-desc">가입 시 등록한 이름과 전화번호 또는 이메일을 입력해 주세요.</p>
    <form id="findIdForm" class="md-form" onsubmit="return submitFindId(event);">
      <label>이름</label><input type="text" name="name" required>
      <label>전화번호</label><input type="tel" name="phone" placeholder="010-0000-0000">
      <label>이메일</label><input type="email" name="email" placeholder="example@email.com">
      <p class="md-hint">전화번호 또는 이메일 중 하나는 반드시 입력해 주세요.</p>
      <div id="findIdResult" class="md-modal-result" style="display:none;"></div>
      <button type="submit" class="md-btn md-btn-b" style="width:100%;">찾기</button>
    </form>
  </div>
</div>

<!-- 비밀번호 찾기 모달 -->
<div class="md-modal" id="findPwModal">
  <div class="md-modal-box">
    <button type="button" class="md-modal-close" onclick="closeModal('findPwModal')">&times;</button>
    <h2>비밀번호 찾기</h2>
    <p class="md-modal-desc">아이디, 이름, 전화번호 또는 이메일을 입력하면 임시 비밀번호를 발급합니다.</p>
    <form id="findPwForm" class="md-form" onsubmit="return submitFindPw(event);">
      <label>아이디</label><input type="text" name="username" required>
      <label>이름</label><input type="text" name="name" required>
      <label>전화번호</label><input type="tel" name="phone" placeholder="010-0000-0000">
      <label>이메일</label><input type="email" name="email" placeholder="example@email.com">
      <p class="md-hint">전화번호 또는 이메일 중 하나는 반드시 입력해 주세요.</p>
      <div id="findPwResult" class="md-modal-result" style="display:none;"></div>
      <button type="submit" class="md-btn md-btn-b" style="width:100%;">임시 비밀번호 발급</button>
    </form>
  </div>
</div>

<script>
function openModal(id) {
  document.getElementById(id).classList.add('show');
  var result = id === 'findIdModal' ? 'findIdResult' : 'findPwResult';
  var el = document.getElementById(result);
  el.style.display = 'none';
  el.textContent = '';
  el.className = 'md-modal-result';
}

function closeModal(id) {
  document.getElementById(id).classList.remove('show');
}

document.querySelectorAll('.md-modal').forEach(function (modal) {
  modal.addEventListener('click', function (e) {
    if (e.target === modal) closeModal(modal.id);
  });
});

function showResult(elId, text, isSuccess) {
  var el = document.getElementById(elId);
  el.textContent = text;
  el.className = 'md-modal-result ' + (isSuccess ? 'success' : 'error');
  el.style.display = 'block';
}

function submitFindId(e) {
  e.preventDefault();
  var form = document.getElementById('findIdForm');
  var fd = new FormData(form);
  if (!fd.get('phone') && !fd.get('email')) {
    showResult('findIdResult', '전화번호 또는 이메일을 입력해 주세요.', false);
    return false;
  }
  fetch(bp('/user/find-id'), { method: 'POST', body: new URLSearchParams(fd) })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.success) {
        showResult('findIdResult', '당신의 아이디는 [' + data.username + '] 입니다.', true);
      } else {
        showResult('findIdResult', data.message || '일치하는 회원 정보가 없습니다.', false);
      }
    })
    .catch(function () {
      showResult('findIdResult', '요청 처리 중 오류가 발생했습니다.', false);
    });
  return false;
}

function submitFindPw(e) {
  e.preventDefault();
  var form = document.getElementById('findPwForm');
  var fd = new FormData(form);
  if (!fd.get('phone') && !fd.get('email')) {
    showResult('findPwResult', '전화번호 또는 이메일을 입력해 주세요.', false);
    return false;
  }
  fetch(bp('/user/find-pw'), { method: 'POST', body: new URLSearchParams(fd) })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.success) {
        showResult('findPwResult', data.message, true);
      } else {
        showResult('findPwResult', data.message || '일치하는 회원 정보가 없습니다.', false);
      }
    })
    .catch(function () {
      showResult('findPwResult', '요청 처리 중 오류가 발생했습니다.', false);
    });
  return false;
}
</script>

<%- include('../partials/footer') %>
