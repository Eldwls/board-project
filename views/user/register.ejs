<%- include('../partials/head', { title: '회원가입' , basePath: basePath, appUrl: appUrl }) %>
<%- include('../partials/header') %>
<div class="md-auth">
  <div class="md-auth-box" style="max-width:480px;">
    <h1>JOIN · 뭐든사</h1>
    <% if (error) { %><div class="md-alert md-alert-err"><%= error %></div><% } %>
    <form action="<%= basePath %>/user/register" method="POST" class="md-form" id="registerForm" onsubmit="return validateRegister();">
      <label>아이디 *</label>
      <input type="text" name="username" id="username" value="<%= form.username || '' %>" required minlength="4" maxlength="20" pattern="[a-zA-Z0-9_]+">
      <label>비밀번호 *</label>
      <input type="password" name="password" id="password" required minlength="4">
      <label>비밀번호 확인 *</label>
      <input type="password" name="password_confirm" id="password_confirm" required minlength="4">
      <label>이름 *</label>
      <input type="text" name="name" id="name" value="<%= form.name || '' %>" required minlength="2">
      <label>성별 (선택)</label>
      <select name="gender">
        <option value="">선택 안 함</option>
        <option value="남성" <%= form.gender === '남성' ? 'selected' : '' %>>남성</option>
        <option value="여성" <%= form.gender === '여성' ? 'selected' : '' %>>여성</option>
        <option value="기타" <%= form.gender === '기타' ? 'selected' : '' %>>기타</option>
      </select>
      <label>나이 (선택)</label>
      <input type="number" name="age" min="1" max="120" value="<%= form.age || '' %>">
      <label>집주소 (선택)</label>
      <input type="text" name="address" value="<%= form.address || '' %>">
      <label>전화번호 (선택)</label>
      <input type="tel" name="phone" value="<%= form.phone || '' %>" placeholder="010-0000-0000">
      <p class="md-hint">※ 전화번호와 이메일 주소는 선택 입력 사항이지만, 향후 아이디/비밀번호 찾기 기능을 이용할 때 본인 인증을 위해 반드시 필요합니다.</p>
      <label>이메일 주소 (선택)</label>
      <input type="email" name="email" value="<%= form.email || '' %>">
      <p class="md-hint">※ 전화번호와 이메일 주소는 선택 입력 사항이지만, 향후 아이디/비밀번호 찾기 기능을 이용할 때 본인 인증을 위해 반드시 필요합니다.</p>
      <button type="submit" class="md-btn md-btn-b" style="width:100%;">가입</button>
    </form>
    <p style="text-align:center;margin-top:16px;font-size:12px;"><a href="<%= basePath %>/user/login">로그인</a></p>
  </div>
</div>
<script>
function validateRegister() {
  var u = document.getElementById('username').value.trim();
  var p = document.getElementById('password').value;
  var pc = document.getElementById('password_confirm').value;
  var n = document.getElementById('name').value.trim();
  if (!/^[a-zA-Z0-9_]{4,20}$/.test(u)) { alert('아이디는 4~20자 영문, 숫자, _ 만 가능합니다.'); return false; }
  if (p.length < 4) { alert('비밀번호는 4자 이상이어야 합니다.'); return false; }
  if (p !== pc) { alert('비밀번호와 비밀번호 확인이 일치하지 않습니다.'); return false; }
  if (n.length < 2) { alert('이름은 2자 이상 입력해 주세요.'); return false; }
  return true;
}
</script>
<%- include('../partials/footer') %>
