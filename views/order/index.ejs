<%- include('../partials/head', { title: '주문내역' , basePath: basePath, appUrl: appUrl }) %>
<%- include('../partials/header') %>
<div class="md-hero"><h1>ORDERS</h1></div>
<div class="md-container">
  <div class="md-panel" style="padding:0;overflow:hidden;">
    <table class="md-table">
      <thead><tr><th>주문번호</th><th>금액</th><th>상태</th><th>결제</th><th>주문일</th><th></th></tr></thead>
      <tbody>
        <% if (!orders.length) { %><tr><td colspan="6" style="text-align:center;padding:32px;">주문 없음</td></tr><% } %>
        <% orders.forEach(function (o) { %>
          <tr>
            <td>#<%= o.id %></td>
            <td><%= o.total_price.toLocaleString() %>원</td>
            <td><%= o.status %></td>
            <td><%= o.payment_method || '-' %></td>
            <td><%= new Date(o.created_at).toLocaleString('ko-KR') %></td>
            <td><a href="<%= basePath %>/order/<%= o.id %>">상세</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
