<%- include('../partials/head', { title: '주문 상세' , basePath: basePath, appUrl: appUrl }) %>
<%- include('../partials/header') %>
<div class="md-container">
  <% if (completed) { %><div class="md-alert">주문이 완료되었습니다. 뭐든사를 이용해 주셔서 감사합니다.</div><% } %>
  <h1 class="md-section-title">주문서 #<%= order.id %></h1>
  <div class="md-panel">
    <p><strong>상태</strong> · <%= order.status %></p>
    <p><strong>결제</strong> · <%= order.payment_method %></p>
    <p><strong>수령인</strong> · <%= order.recipient_name %> (<%= order.phone %>)</p>
    <p><strong>주소</strong> · <%= order.address %></p>
    <p><strong>총액</strong> · <%= order.total_price.toLocaleString() %>원</p>
    <p style="font-size:12px;color:#9e9e9e;"><%= new Date(order.created_at).toLocaleString('ko-KR') %></p>
  </div>
  <div class="md-panel" style="padding:0;overflow:hidden;">
    <table class="md-table">
        <thead><tr><th>상품</th><th>사이즈</th><th>단가</th><th>수량</th><th>소계</th></tr></thead>
      <tbody>
        <% items.forEach(function (it) { %>
          <tr>
            <td><% if (it.image) { %><img src="<%= it.image %>" style="width:32px;height:42px;object-fit:cover;vertical-align:middle;margin-right:8px;"><% } %><%= it.product_name || '상품#' + it.product_id %></td>
            <td><%= it.size %></td>
            <td><%= it.price.toLocaleString() %>원</td>
            <td><%= it.quantity %></td>
            <td><%= (it.price * it.quantity).toLocaleString() %>원</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <a href="<%= basePath %>/order" class="md-btn md-btn-g">주문 목록</a>
  <a href="<%= basePath %>/products" class="md-btn md-btn-b">쇼핑 계속</a>
</div>
<%- include('../partials/footer') %>
